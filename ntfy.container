[Unit]
Description=Ntfy Push Notification Service
After=network-online.target

[Container]
Image=docker.io/binwiederhier/ntfy:latest
ContainerName=ntfy
Exec=serve --cache-file /var/cache/ntfy/cache.db
Volume=%h/vikunja-snooze/ntfy-data:/var/cache/ntfy:Z
Network=srv-net
PublishPort=8080:80

# Environment configurations
Environment=NTFY_BASE_URL=http://localhost:8080
# You can set AUTH here if needed later.

[Install]
WantedBy=default.target
WantedBy=multi-user.target